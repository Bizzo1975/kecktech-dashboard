---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ValueCard from '../components/ValueCard.astro';
import data from '../data/home.json';
import servicesData from '../data/services.json';

// Build service cards from displayIds referencing services.json
const serviceColorMap: Record<string, string> = {
  'white-glove': '#0D6E6E',
  'haas': '#2E7D32',
  'ai-apps': '#C07810',
  'senior-tech': '#7C3AED',
  'break-fix': '#1E3A5F',
  'time-block': '#0D6E6E',
  'professional-services': '#4A6887',
};
const defaultColors = ['#0D6E6E', '#2E7D32', '#C07810', '#7C3AED', '#4A6887'];

const displayIds = data.services.displayIds || [];
const services = displayIds
  .map((id: string) => servicesData.services?.find((s: any) => s.id === id))
  .filter(Boolean)
  .filter((s: any) => s.available !== false)
  .map((s: any, i: number) => ({
    icon: s.icon || '💼',
    heading: s.name,
    description: s.body || s.description || '',
    price: s.price,
    color: serviceColorMap[s.id] || defaultColors[i % defaultColors.length],
    href: `/services#${s.id}`,
  }));

const valueColors = ['#C07810', '#0D6E6E', '#1E3A5F', '#4A6887'];

const values = data.values.cards.map((card: any, i: number) => ({
  ...card,
  color: valueColors[i],
}));
---

<Base
  title="Reliable IT That Actually Cares"
  description="Kecktech IT Solutions — Reliable IT support for small businesses and seniors. Break/fix, time-block contracts, senior concierge, and professional services. Park City, Kansas."
>

  <Hero
    h1={data.hero.h1}
    subtitle={data.hero.subtitle}
    bgImage="/images/home-hero-bg.jpg"
    overlayColor="#1E3A5F"
    overlayOpacity={0.68}
    ctaLabel={data.hero.cta}
    ctaHref="/contact?type=general"
    ctaSecondaryLabel={data.hero.ctaSecondary}
    ctaSecondaryHref="#services"
  />

  <!-- ── Services ────────────────────────────────────────── -->
  <section id="services" class="services-section">
    <div class="container">
      <span class="section-label">{data.services.label}</span>
      <h2>{data.services.heading}</h2>
      <p class="section-intro">{data.services.intro}</p>
      {services.length > 0 ? (
        <div class={services.length >= 4 ? 'grid-4' : services.length === 3 ? 'grid-3' : services.length === 2 ? 'grid-2' : 'grid-1'}>
          {services.map(s => <ServiceCard {...s} />)}
        </div>
      ) : (
        <p class="section-intro">Services launching soon — contact us for details.</p>
      )}
    </div>
  </section>

  <!-- ── Why Kecktech ──────────────────────────────────────────────────── -->
  <section class="why-section">
    <div class="container">
      <span class="section-label">{data.values.label}</span>
      <h2>{data.values.heading}</h2>
      <p class="section-intro">{data.values.intro}</p>
      <div class="grid-4">
        {values.map(v => <ValueCard {...v} />)}
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ───────────────────────────────────────────────────── -->
  <section class="cta-banner">
    <div class="container">
      <h2>{data.cta.heading}</h2>
      <p>{data.cta.body}</p>
      <a href="/contact?type=general" class="btn-primary">{data.cta.button}</a>
    </div>
  </section>

</Base>

<style>
/* Section labels: gold on home page */
.services-section .section-label,
.why-section .section-label { color: var(--gold); }

.services-section { background: var(--off-white); }
.services-section h2 { margin: 8px 0 4px; }
.services-section h2::after {
  content: '';
  display: block;
  width: 56px;
  height: 3px;
  background: var(--gold);
  border-radius: 2px;
  margin-top: 10px;
  margin-bottom: 16px;
}

/* Subtle teal-tinted background for Why section */
.why-section { background: rgba(13, 110, 110, 0.04); }
.why-section h2 { margin: 8px 0 4px; }
.why-section h2::after {
  content: '';
  display: block;
  width: 56px;
  height: 3px;
  background: var(--teal);
  border-radius: 2px;
  margin-top: 10px;
  margin-bottom: 16px;
}

.section-intro {
  color: var(--steel);
  font-size: 17px;
  margin-bottom: 40px;
  max-width: 680px;
}

.cta-banner { background: var(--navy); text-align: center; }
.cta-banner h2 { color: #fff; margin-bottom: 14px; }
.cta-banner p { color: var(--muted); font-size: 18px; margin-bottom: 32px; }
</style>
