---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import data from '../data/about.json';
import Icon from '../components/Icon.astro';
---

<Base
  title="About"
  description="Kecktech IT Solutions — An independent IT company in Park City, Kansas. Meet the team, learn our story, and see what makes Kecktech different."
>

  <Hero
    h1={data.hero.h1}
    subtitle={data.hero.subtitle}
    bgImage="/images/about-bg-img.jpg"
    overlayColor="#C07810"
    overlayOpacity={0.80}
  />

  <!-- ── Mission ──────────────────────────────────────────────────────── -->
  <section class="mission-section">
    <div class="container mission-inner">
      <div>
        <span class="section-label">{data.mission.label}</span>
        <h2>{data.mission.heading}</h2>
        <p>{data.mission.body}</p>
        <blockquote class="pull-quote">"{data.mission.quote}"</blockquote>
        <p>{data.mission.body2}</p>
      </div>
      <div class="mission-img-wrap">
        <img src="/images/why-choose-us.jpg" alt="Kecktech data center facility" class="mission-img" />
      </div>
    </div>
  </section>

  <!-- ── Values ──────────────────────────────────────────────────────── -->
  <section class="values-section">
    <div class="container">
      <span class="section-label">{data.values.label}</span>
      <h2>{data.values.heading}</h2>
      <div class="values-grid">
        {data.values.cards.map(v => (
          <div class="value-card">
            <div class="val-icon-wrap" aria-hidden="true"><Icon name={v.icon} size={24} /></div>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Team ────────────────────────────────────────────────────────── -->
  <section class="team-section">
    <div class="container">
      <span class="section-label">{data.team.label}</span>
      <h2>{data.team.heading}</h2>
      <div class="grid-2 team-grid">
        {data.team.members.map(m => (
          <div class="team-member">
            <img src={m.photo} alt={m.photoAlt} class="team-photo" />
            <h3>{m.name}</h3>
            <p class="team-title">{m.title}</p>
            <p>{m.bio}</p>
            {m.website && (
              <a href={m.website} target="_blank" rel="noopener noreferrer" class="team-website">
                Personal Website ↗
              </a>
            )}
          </div>
        ))}
      </div>
      <div class="team-contact">
        <a href="tel:+13167680034" class="team-contact-item">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (316) 768-0034
        </a>
        <a href="mailto:support@kecktech.net" class="team-contact-item">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          support@kecktech.net
        </a>
      </div>
    </div>
  </section>

  <!-- ── Facility / Fundraising Goal ────────────────────────────────── -->
  <section class="facility-section" id="goal">
    <div class="container">
      <span class="section-label" style="color: var(--gold)">{data.facility.label}</span>
      <h2>{data.facility.heading}</h2>
      <p class="facility-intro">{data.facility.body}</p>

      <!-- Goal stats — labeled as targets -->
      <div class="stat-bar">
        {data.facility.stats.map(s => (
          <div class="stat-item">
            <span class="stat-number">{s.number}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>

      <!-- Donate block -->
      <div class="donate-block">
        <h3 class="donate-heading">{data.facility.donateHeading}</h3>
        <p class="donate-body">{data.facility.donateBody}</p>
        <a href={data.facility.donateUrl} target="_blank" rel="noopener noreferrer" class="btn-donate">
          {data.facility.donateLabel}
        </a>
      </div>

      <div class="facility-cta">
        <a href="/contact" class="btn-primary">{data.facility.ctaPrimary}</a>
        <a href="/services" class="btn-white">{data.facility.ctaSecondary}</a>
      </div>
    </div>
  </section>

</Base>

<style>
.mission-section { background: var(--off-white); }
.mission-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
.mission-img { border-radius: 10px; width: 100%; object-fit: cover; max-height: 380px; }
.mission-section h2 { margin: 8px 0 20px; }

.values-section { background: var(--white); }
.values-section h2 { margin: 8px 0 32px; }
.values-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 24px;
}
.values-grid > * { grid-column: span 2; }
.values-grid > *:nth-child(4) { grid-column: 2 / span 2; }
.values-grid > *:nth-child(5) { grid-column: 4 / span 2; }
.value-card { background: var(--off-white); border-radius: 10px; padding: 28px; }
.val-icon-wrap { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; background: color-mix(in srgb, var(--navy) 8%, transparent); color: var(--navy); margin-bottom: 12px; }
.value-card h3 { color: var(--navy); font-size: 18px; margin-bottom: 10px; }
.value-card p { font-size: 15px; color: var(--charcoal); margin: 0; line-height: 1.7; }

.team-section { background: var(--off-white); }
.team-section h2 { margin: 8px 0 40px; }
.team-member { display: flex; flex-direction: column; }
.team-title { font-family: var(--font-heading); font-size: 14px; color: var(--steel); margin-bottom: 12px; }
.team-contact { display: flex; gap: 32px; flex-wrap: wrap; margin-top: 48px; padding-top: 32px; border-top: 1px solid #e2e8f0; }
.team-contact-item { display: flex; align-items: center; gap: 8px; color: var(--navy); text-decoration: none; font-family: var(--font-heading); font-weight: 600; }
.team-contact-item:hover { color: var(--gold); }
.team-website { display: inline-block; margin-top: 10px; color: var(--gold); font-family: var(--font-heading); font-weight: 600; font-size: 15px; text-decoration: underline; }
.team-website:hover { color: var(--gold-dark); }

.facility-section { background: var(--navy); color: #fff; text-align: center; }
.facility-section h2 { color: #fff; margin: 8px 0 20px; }
.facility-intro { color: rgba(255,255,255,0.8); max-width: 700px; margin: 0 auto 8px; font-size: 17px; }
.facility-cta { display: flex; gap: 16px; justify-content: center; margin-top: 32px; flex-wrap: wrap; }

.donate-block {
  margin: 36px auto 0;
  max-width: 560px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(192,120,16,0.5);
  border-radius: 12px;
  padding: 28px 32px;
}
.donate-heading { color: var(--gold); font-family: var(--font-heading); font-size: 20px; font-weight: 700; margin-bottom: 10px; }
.donate-body { color: rgba(255,255,255,0.78); font-size: 15px; line-height: 1.7; margin-bottom: 20px; }
.btn-donate {
  display: inline-block;
  background: var(--gold);
  color: #fff;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 16px;
  padding: 13px 28px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-donate:hover { background: #a06510; }

@media (max-width: 768px) {
  .mission-inner { grid-template-columns: 1fr; }
  .mission-img-wrap { display: none; }
  .values-grid { grid-template-columns: repeat(2, 1fr); }
  .values-grid > *, .values-grid > *:nth-child(4), .values-grid > *:nth-child(5) { grid-column: span 1; }
}
@media (max-width: 560px) {
  .values-grid { grid-template-columns: 1fr; }
}
</style>
