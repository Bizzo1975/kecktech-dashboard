---
interface Props {
  icon: string;
  heading: string;
  body: string;
  color?: string;
}
import Icon from './Icon.astro';
const { icon, heading, body, color } = Astro.props;
---

<div class="val-card" style={color ? `--val-accent: ${color}` : ''}>
  <div class="val-icon val-icon--circle" aria-hidden="true"><Icon name={icon} size={24} /></div>
  <h3 class="val-heading">{heading}</h3>
  <p class="val-body">{body}</p>
</div>

<style>
.val-card {
  background: var(--white);
  border-radius: 10px;
  padding: 32px 28px;
  box-shadow: 0 2px 16px rgba(30,58,95,0.06);
  border-bottom: 3px solid var(--val-accent, var(--gold));
}
.val-icon { margin-bottom: 16px; color: var(--val-accent, var(--gold)); }
.val-icon--circle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--val-accent) 12%, transparent);
  font-size: 28px;
}
.val-heading { color: var(--navy); font-size: 20px; margin-bottom: 10px; }
.val-body { color: var(--charcoal); font-size: 15px; line-height: 1.7; margin: 0; }
</style>
