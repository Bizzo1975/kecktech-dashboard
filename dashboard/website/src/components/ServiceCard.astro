---
import Icon from './Icon.astro';
interface Props {
  icon: string;
  heading: string;
  description: string;
  price: string;
  color: string;
  href?: string;
  priceNote?: string;
}
const { icon, heading, description, price, color, href = '/contact', priceNote } = Astro.props;
---

<div class="svc-card" style={`--accent: ${color}`}>
  <div class="svc-icon-wrap">
    <Icon name={icon} size={28} />
  </div>
  <div class="svc-price">{price}</div>
  <h3 class="svc-heading">{heading}</h3>
  <p class="svc-desc">{description}</p>
  {priceNote && <p class="svc-note">{priceNote}</p>}
  <a href={href} class="svc-link">Learn more &rarr;</a>
</div>

<style>
.svc-card {
  background: var(--white);
  border-radius: 10px;
  padding: 32px 28px;
  box-shadow: 0 2px 16px rgba(30,58,95,0.08);
  border-top: 4px solid var(--accent);
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.svc-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(30,58,95,0.14); }

.svc-icon-wrap {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  color: var(--accent);
}
.svc-price {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 13px;
  border-radius: 20px;
  padding: 3px 12px;
  width: fit-content;
}
.svc-heading { color: var(--navy); font-size: 19px; margin: 0; }
.svc-desc { color: var(--charcoal); font-size: 15px; line-height: 1.7; flex: 1; margin: 0; }
.svc-note { color: var(--steel); font-size: 13px; font-style: italic; margin: 0; }
.svc-link {
  font-family: var(--font-heading);
  font-size: 14px;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  margin-top: 4px;
}
.svc-link:hover { text-decoration: underline; }
</style>