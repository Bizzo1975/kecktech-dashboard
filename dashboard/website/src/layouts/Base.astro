---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Kecktech IT Solutions — Reliable IT support for small businesses and seniors in Park City, Kansas. Human-first, privacy-focused, built to last.',
  ogImage = '/brand/colored-logo.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://www.kecktech.net');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Kecktech IT Solutions</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | Kecktech IT Solutions`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/brand/transparent-logo.png" />

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
.skip-link {
  position: absolute;
  top: -100px;
  left: 16px;
  background: var(--gold);
  color: #fff;
  padding: 10px 16px;
  border-radius: 0 0 6px 6px;
  font-family: var(--font-heading);
  font-weight: 600;
  z-index: 9999;
  text-decoration: none;
  transition: top 0.2s;
}
.skip-link:focus { top: 0; }
</style>
